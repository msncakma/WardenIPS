#!/bin/bash
set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

if [ "$(id -u)" -ne 0 ]; then
    echo -e "${RED}✗ Service management requires root privileges.${NC}"
    echo "Please run: sudo wardenips.stop"
    exit 1
fi

echo "🛑 Stopping WardenIPS service..."
if systemctl stop wardenips.service; then
    echo -e "${YELLOW}✓ WardenIPS service stopped${NC}"
else
    echo -e "${RED}✗ Failed to stop WardenIPS service${NC}"
    exit 1
fi