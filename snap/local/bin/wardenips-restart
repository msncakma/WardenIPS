#!/bin/bash
set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

if [ "$(id -u)" -ne 0 ]; then
    echo -e "${RED}✗ Service management requires root privileges.${NC}"
    echo "Please run: sudo wardenips.restart"
    exit 1
fi

echo "🔄 Restarting WardenIPS service..."
if systemctl restart wardenips.service; then
    echo -e "${GREEN}✓ WardenIPS service restarted${NC}"
    systemctl --no-pager status wardenips.service
else
    echo -e "${RED}✗ Failed to restart WardenIPS service${NC}"
    exit 1
fi