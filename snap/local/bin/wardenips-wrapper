#!/bin/bash
set -e

# Snap environment paths
INSTALL_DIR="${SNAP_DATA}"
CONFIG_FILE="${SNAP_DATA}/config.yaml"
PYTHON_BIN="python3"
MAIN_FILE="${SNAP}/lib/python3.10/site-packages/main.py"
SERVICE_NAME="wardenips"

# Colors (ANSI codes)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

print_banner() {
    printf "\n"
    printf "${CYAN}${BOLD}"
    printf "╔════════════════════════════════════════════╗\n"
    printf "║                                            ║\n"
    printf "║  %b   WardenIPS (Snap)   %b              ║\n" "$BLUE" "$CYAN"
    printf "║                                            ║\n"
    printf "║     Autonomous Intrusion Protection        ║\n"
    printf "║                                            ║\n" 
    printf "╚════════════════════════════════════════════╝\n"
    printf "${NC}\n"
}

usage() {
    print_banner
    printf "${GREEN}${BOLD}Usage:${NC} wardenips <command> [args]\n\n"
    printf "${BOLD}Core Commands:${NC}\n"
    printf "  ${CYAN}console${NC}         Run in console mode with direct logs\n"
    printf "  ${CYAN}start${NC}           Start the WardenIPS service\n"
    printf "  ${CYAN}stop${NC}            Stop the WardenIPS service\n"
    printf "  ${CYAN}restart${NC}         Restart the WardenIPS service\n\n"
    printf "${BOLD}Status & Monitoring:${NC}\n"
    printf "  ${CYAN}status${NC}          Show service status\n"
    printf "  ${CYAN}logs${NC}            Stream live service logs\n"
    printf "  ${CYAN}summary${NC}         Display database statistics\n\n"
    printf "${BOLD}Configuration:${NC}\n"
    printf "  ${CYAN}configure${NC}       Initial setup and configuration\n"
    printf "  ${CYAN}config${NC}          Print configuration file path\n"
    printf "  ${CYAN}path${NC}            Print installation directory\n"
    printf "  ${CYAN}edit${NC}            Edit configuration\n\n"
    printf "${BOLD}Utilities:${NC}\n"
    printf "  ${CYAN}version${NC}         Show WardenIPS version\n"
    printf "  ${CYAN}help${NC}            Show this help message\n\n"
    printf "${YELLOW}Note: WardenIPS requires root privileges for firewall management.${NC}\n"
    printf "Use: ${CYAN}sudo wardenips <command>${NC}\n\n"
}

check_setup() {
    if [ ! -f "$CONFIG_FILE" ]; then
        printf "${YELLOW}⚠ WardenIPS not configured. Run: ${CYAN}$ sudo wardenips configure${NC}\n"
        exit 1
    fi
}

case "${1:-help}" in
    help|-h|--help)
        usage
        ;;
    version)
        $PYTHON_BIN "$MAIN_FILE" --version
        ;;
    summary|status-summary)
        check_setup
        $PYTHON_BIN "$MAIN_FILE" --config "$CONFIG_FILE" --status
        ;;
    console)
        check_setup
        print_banner
        exec $PYTHON_BIN "$MAIN_FILE" --config "$CONFIG_FILE"
        ;;
    configure)
        exec wardenips.configure
        ;;
    start)
        check_setup
        exec wardenips.start
        ;;
    stop)
        exec wardenips.stop
        ;;
    restart)
        check_setup
        exec wardenips.restart
        ;;
    status)
        exec wardenips.status
        ;;
    logs)
        exec wardenips.logs
        ;;
    config)
        printf "%s\n" "$CONFIG_FILE"
        ;;
    path)
        printf "%s\n" "$INSTALL_DIR"
        ;;
    edit)
        if [ -f "$CONFIG_FILE" ]; then
            exec ${EDITOR:-nano} "$CONFIG_FILE"
        else
            printf "${YELLOW}⚠ Run 'wardenips configure' first${NC}\n"
            exit 1
        fi
        ;;
    *)
        printf "${RED}✗ Unknown command: ${BOLD}$1${NC}\n" >&2
        printf "Run '${CYAN}wardenips help${NC}' for available commands.\n" >&2
        exit 1
        ;;
esac