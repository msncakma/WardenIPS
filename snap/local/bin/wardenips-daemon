#!/bin/bash
set -e

# WardenIPS Daemon mode for Snap
# Direct systemd service entry point

INSTALL_DIR="${SNAP_DATA}"
CONFIG_FILE="${SNAP_DATA}/config.yaml"
PYTHON_BIN="python3"
MAIN_FILE="${SNAP}/lib/python3.10/site-packages/main.py"

# Ensure configuration exists
if [ ! -f "$CONFIG_FILE" ]; then
    echo "ERROR: WardenIPS not configured. Run 'sudo wardenips.configure' first." >&2
    exit 1
fi

# Execute WardenIPS in daemon mode
exec $PYTHON_BIN "$MAIN_FILE" --config "$CONFIG_FILE"